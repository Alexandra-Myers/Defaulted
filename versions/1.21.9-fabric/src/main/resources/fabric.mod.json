{
  "schemaVersion": 1,
  "id": "defaulted",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "Alexandra"
  ],
  "contact": {
    "sources": "https://github.com/Alexandra-Myers/Defaulted",
    "issues": "https://github.com/Alexandra-Myers/Defaulted/issues"
  },
  "icon": "assets/icon.png",
  "license": "${mod_license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.atlas.defaulted.fabric.DefaultedFabric"
    ],
    "client": [
      "net.atlas.defaulted.fabric.client.DefaultedFabricClient"
    ]
  },
  "mixins": [
    "defaulted.mixins.json"
  ],
  "depends": {
    "fabric-api": ">=${fabric_api_version}",
    "fabricloader": ">=${fabric_version}",
    "minecraft": "${minecraft}",
    "java": ">=${java}"
  },
  "suggests": {
    "another-mod": "*"
  },
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_1792": ["net/atlas/defaulted/extension/ItemExtensions"],
      "net/minecraft/class_1799": ["net/atlas/defaulted/extension/ItemStackExtensions"],
      "net/minecraft/class_6880$class_6883": ["net/atlas/defaulted/extension/ReferenceHolderExtensions"]
    }
  }
}
